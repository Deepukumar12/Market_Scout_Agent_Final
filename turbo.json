{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "public/**", "package.json", "tsconfig.json", "vite.config.ts"],
      "outputs": ["dist/**", ".next/**"],
      "cache": true
    },
    "lint": {
      "inputs": ["src/**", ".eslintrc.cjs", ".eslintignore"],
      "cache": true
    },
    "type-check": {
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
