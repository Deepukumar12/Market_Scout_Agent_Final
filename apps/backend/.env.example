# ===================================================
# MARKET SCOUT AGENT - MASTER PRODUCTION SECRETS
# ===================================================

# 1. CORE SYSTEM SETTINGS
ENVIRONMENT=production
PROJECT_NAME=SCOUTIQ
SECRET_KEY=YOUR_SECURE_JWT_SECRET_KEY
API_V1_STR=/api/v1
CORS_ORIGINS=https://app.marketscout.ai,https://admin.marketscout.ai
ALLOWED_HOSTS=api.marketscout.ai

# 2. INFRASTRUCTURE
MONGODB_URL=mongodb://db:27017
DATABASE_NAME=scoutiq_db
REDIS_URL=redis://redis:6379/0

# 3. PRIMARY AI ENGINE (MANDATORY)
# Get from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
LLM_PROVIDER=gemini

# 4. SECONDARY AI ENGINE (FALLBACK)
# Get from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# 5. SEARCH & CONTENT ACQUISITION (MANDATORY)
# Get from: https://tavily.ai/
TAVILY_API_KEY=your_tavily_api_key_here
# Get from: https://firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# 6. MARKET INTELLIGENCE APIs (PRODUCTION)
# Financial Data: https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
# Financial News: https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_key_here
# Financial Modeling: https://site.financialmodelingprep.com/
FMP_API_KEY=your_fmp_key_here

# 7. COMPANY INTELLIGENCE APIs (PRODUCTION)
# News: https://newsapi.org/
NEWSAPI_API_KEY=your_newsapi_key_here
# News (Global): https://gnews.io/
GNEWS_API_KEY=your_gnews_key_here
# Company Data: https://www.crunchbase.com/
CRUNCHBASE_API_KEY=your_crunchbase_api_key_here
# PDL: https://www.peopledatalabs.com/
PEOPLE_DATA_LABS_API_KEY=your_pdl_api_key_here

# 8. SOCIAL & REPOSITORY INTELLIGENCE
# GitHub: Personal Access Token (PAT)
GITHUB_TOKEN=your_github_token_here
# Reddit: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=ScoutIQ-Production/1.0

# 9. MONITORING
# Sentry: https://sentry.io/
SENTRY_DSN=your_sentry_dsn_here

# 10. SYSTEM MODES
MOCK_MODE=False
DEBUG=False
