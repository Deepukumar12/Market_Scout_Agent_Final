# ===================================================
# MARKET SCOUT AGENT - EXAMPLE CONFIGURATION
# ===================================================

# ---------------------------------------------------
# 1. CORE PROJECT SETTINGS
# ---------------------------------------------------
ENVIRONMENT=development
PROJECT_NAME=SCOUTIQ
API_V1_STR=/api/v1
CORS_ORIGINS=*
ALLOWED_HOSTS=*

# ---------------------------------------------------
# 2. SECURITY & AUTHENTICATION
# ---------------------------------------------------
SECRET_KEY=YOUR_SUPER_SECRET_RANDOM_KEY_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=300

# ---------------------------------------------------
# 3. DATABASE & CACHE
# ---------------------------------------------------
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=scoutiq_db
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------
# 4. LLM SERVICE PRIORITY
# ---------------------------------------------------
LLM_PROVIDER=gemini

# ---------------------------------------------------
# 5. GOOGLE GEMINI (Primary Intelligence)
# ---------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_MAX_OUTPUT_TOKENS=2048

# ---------------------------------------------------
# 6. OLLAMA (Local LLM Fallback)
# ---------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b-q4

# ---------------------------------------------------
# 7. GROQ (Ad-hoc Summarization Fallback)
# ---------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ---------------------------------------------------
# 8. SEARCH & CONTENT ACQUISITION
# ---------------------------------------------------
TAVILY_API_KEY=your_tavily_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ---------------------------------------------------
# 9. GITHUB INTELLIGENCE
# ---------------------------------------------------
GITHUB_TOKEN=your_github_token_here

# ---------------------------------------------------
# 10. SYSTEM BEHAVIOR
# ---------------------------------------------------
MOCK_MODE=False

# Email Configuration for Alerting
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# ---------------------------------------------------
# 11. ADVANCED INTELLIGENCE & PRODUCTION APIs
# ---------------------------------------------------

# Search Intelligence
SERPAPI_API_KEY=your_serpapi_key_here
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_CX=your_google_search_cx_here

# Company Intelligence
CRUNCHBASE_API_KEY=your_crunchbase_api_key_here
CLEARBIT_API_KEY=your_clearbit_api_key_here
PEOPLE_DATA_LABS_API_KEY=your_pdl_api_key_here

# Financial Intelligence
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
FINNHUB_API_KEY=your_finnhub_key_here
FMP_API_KEY=your_fmp_key_here

# News Intelligence
NEWSAPI_API_KEY=your_newsapi_key_here
GNEWS_API_KEY=your_gnews_key_here

# Community & Social
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=ScoutIQ/1.0
YOUTUBE_API_KEY=your_youtube_api_key_here

# ---------------------------------------------------
# 12. OTHER AI MODELS (Optional)
# ---------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# ---------------------------------------------------
# 13. MONITORING & ERROR TRACKING
# ---------------------------------------------------
# Sentry DSN for production crash reporting
SENTRY_DSN=your_sentry_dsn_here
